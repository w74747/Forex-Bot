# انسخ هذا الملف إلى .env واملأه محليًا فقط — لا ترفع .env أبدًا لـ GitHub
# على Railway: أضف كل هذه في تبويب Variables للخدمة مباشرة (بدون ملف)

# ---------- Open API (البيانات + المصادقة + SL/TP) ----------
CTRADER_CLIENT_ID=
CTRADER_CLIENT_SECRET=
CTRADER_ACCESS_TOKEN=
CTRADER_REFRESH_TOKEN=
CTRADER_ACCOUNT_ID=
CTRADER_USE_LIVE=false

# ---------- FIX API (تنفيذ الأوامر - جلسة TRADE) ----------
# احصل عليها من: cTrader ID -> إعدادات حسابك -> FIX API
CTRADER_FIX_HOST=
CTRADER_FIX_PORT=5201
CTRADER_FIX_SSL=false
CTRADER_FIX_USERNAME=
CTRADER_FIX_PASSWORD=
CTRADER_FIX_SENDER_COMP_ID=
CTRADER_FIX_SENDER_SUB_ID=TRADE
CTRADER_FIX_TARGET_COMP_ID=cServer
CTRADER_FIX_TARGET_SUB_ID=TRADE
CTRADER_FIX_BEGIN_STRING=FIX.4.4
CTRADER_FIX_HEARTBEAT=30

# ---------- تيليجرام ----------
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ---------- إدارة المخاطر ----------
MAX_DAILY_DRAWDOWN_PCT=4.0
MAX_CONCURRENT_POSITIONS=2
RISK_PER_TRADE_PCT=1.0

# ---------- عام ----------
# true = لا يُرسل أي أمر فعلي، فقط يسجّل ما كان سيفعله (ابدأ بهذا دائمًا)
DRY_RUN=true

# مسار حفظ العداد الشهري (اجعله داخل Railway Volume دائم في الإنتاج، مثل /data/...)
MONTHLY_COUNTER_PATH=monthly_counter.json
